# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/ai-accountant
# Alias supported by the new bootstrap utility
MONGO_URI=mongodb://localhost:27017/ai-accountant
# Optional fallback used by local development if the primary URI is unavailable
MONGODB_FALLBACK_URI=mongodb://127.0.0.1:27017/ai-accountant
# Explicitly allow the backend to start without MongoDB (disabled by default)
ALLOW_DEGRADED_MODE=false
# Retry tuning for MongoDB bootstrap
MONGODB_RETRY_ATTEMPTS=3
MONGODB_RETRY_BASE_DELAY_MS=500
# Optional Redis health reporting
REDIS_URL=

# JWT Secret (Generate a secure random string)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# API Keys
GOOGLE_API_KEY=your-google-api-key
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# Client URL (Frontend)
CLIENT_URL=http://localhost:5173

# Frontend URL used in password reset emails (link target)
FRONTEND_URL=http://localhost:5173

# Password reset token TTL in minutes
RESET_PASSWORD_TOKEN_TTL_MINUTES=60

# SMTP (Email) Configuration
# If not set, backend will log the reset link in the console (dev only).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=no-reply@yourdomain.com

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
